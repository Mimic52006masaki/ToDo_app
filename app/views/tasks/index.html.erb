<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>タスク一覧</title>
  <%= stylesheet_link_tag 'tasks', media: 'all' %>
</head>
<body>
  <div class="container">
    <h1>タスク一覧</h1>

    <div class="new-button-wrapper">
      <%= link_to "新規作成", new_task_path, class: "button" %>
    </div>

    <ul class="task-list">
      <% @tasks.each do |task| %>
        <li class="task-item">
          <h2><%= task.title %></h2>
          <p><%= simple_format(task.detail) %></p>
          <p>完了: <span class="<%= task.completed ? 'completed' : 'not-completed' %>"><%= task.completed ? "はい" : "いいえ" %></span></p>

          <div class="actions">
            <%= link_to "編集", edit_task_path(task), class: "edit" %>
            <%= link_to "詳細", task_path(task), class: "edit" %>
            <%= button_to "削除", task_path(task), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "delete" %>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</body>
</html>
